{
  "name": "smart-booking-crm-backend",
  "version": "1.0.0",
  "description": "Backend for Smart Booking CRM",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node scripts/setupLocalDB.js",
    "sync-db": "node scripts/syncDatabases.js",
    "export-data": "node -e \"require('./utils/localDataService').exportData() && console.log('Data exported successfully')\"",
    "backup": "node -e \"const path = require('path'); const timestamp = new Date().toISOString().replace(/:/g, '-'); const exportPath = path.join(__dirname, 'data', `backup-manual-${timestamp}.json`); require('./utils/localDataService').exportData(exportPath) && console.log(`Backup created at ${exportPath}`)\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.8.6",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
